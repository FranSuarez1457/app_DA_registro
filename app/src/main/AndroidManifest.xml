<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TemplateDemo"
        tools:targetApi="31">

        <activity
            android:name=".login.loginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".home.homeActivity" android:exported="false"/>
        <activity android:name=".projectList.projectListActivity" android:exported="false"/>
        <activity android:name=".projectDetail.projectDetailActivity" android:exported="false"/>
        <activity android:name=".registerProject.registerProjectActivity" android:exported="false"/>
        <activity android:name=".registerTask.registerTaskActivity" android:exported="false"/>
        <activity android:name=".status.statusActivity" android:exported="false"/>

    </application>

</manifest>